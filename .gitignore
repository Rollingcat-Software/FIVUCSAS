# ============================================================================
# FIVUCSAS - Root .gitignore
# ============================================================================

# Environment variables
.env
.env.*.local
.env.gcp
.env.local
.env.prod
.env.staging

# IDE / editor
*.swo
*.swp
*~
.idea/
.vscode/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
docker-compose.override.yml

# Python build artefacts
*.pyc
*.pyo
__pycache__/

# Temporary files
*.bak
*.tar.gz
*.temp
*.tmp
.cache/

# OS files
.DS_Store
Thumbs.db
nul

# Build artifacts
*.zip

# Archive and backup folders
/_backup_before_submodules/

# Claude metadata
.claude/

# Generated verify-widget bundle artifacts (built via npm run build:widget)
verify-widget/html/assets/*.css
verify-widget/html/assets/*.js
verify-widget/html/assets/*.js.map
