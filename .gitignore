# ============================================================================
# FIVUCSAS - Root .gitignore
# ============================================================================

# Environment variables
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
docker-compose.override.yml

# Temporary files
*.tmp
*.temp
.cache/

# OS files
Thumbs.db
.DS_Store
nul

# Build artifacts
*.zip

# Archive and backup folders
/archive/
/_backup_before_submodules/

# Claude Code
.claude/settings.local.json
.claude/worktrees/
