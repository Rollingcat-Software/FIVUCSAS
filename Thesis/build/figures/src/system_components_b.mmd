    PERS --> PGV
    STORE --> VOL

    classDef drv fill:#dce8f5,stroke:#2e5e8c,stroke-width:1.5px;
    classDef app fill:#f5f5f5,stroke:#555555,stroke-width:1px;
    classDef dom fill:#ebebeb,stroke:#333333,stroke-width:1.5px;
    classDef inf fill:#f5f5f5,stroke:#555555,stroke-width:1px;
