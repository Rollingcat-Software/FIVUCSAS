{
  "dashboard": {
    "title": "Biometric Processor - Performance & Quality",
    "uid": "biometric-processor",
    "tags": ["biometric", "processor", "ml"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Enrollment Request Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(biometric_enrollment_requests_total[5m])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ],
        "legend": {"show": true}
      },
      {
        "id": 2,
        "title": "Enrollment Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "(sum(rate(biometric_enrollment_errors_total[5m])) / sum(rate(biometric_enrollment_requests_total[5m]))) * 100",
            "legendFormat": "Error Rate %",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "Error %", "max": 100, "min": 0},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [10], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "High Enrollment Error Rate",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 3,
        "title": "Enrollment Duration (p50, p95, p99)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(biometric_enrollment_duration_seconds_bucket{status=\"success\"}[5m])) by (le))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(biometric_enrollment_duration_seconds_bucket{status=\"success\"}[5m])) by (le))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(biometric_enrollment_duration_seconds_bucket{status=\"success\"}[5m])) by (le))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 4,
        "title": "Quality Score Distribution",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(biometric_enrollment_quality_score_bucket[10m])) by (le))",
            "legendFormat": "Median",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(biometric_enrollment_quality_score_bucket[10m])) by (le))",
            "legendFormat": "p95",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "none", "label": "Quality Score", "max": 1, "min": 0},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "Liveness Score Distribution",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(biometric_enrollment_liveness_score_bucket[10m])) by (le))",
            "legendFormat": "Median",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(biometric_enrollment_liveness_score_bucket[10m])) by (le))",
            "legendFormat": "p95",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "none", "label": "Liveness Score", "max": 1, "min": 0},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "ML Pipeline Timings",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(biometric_face_detection_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Face Detection p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(biometric_quality_assessment_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Quality Assessment p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(biometric_liveness_detection_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Liveness Detection p95",
            "refId": "C"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(biometric_embedding_extraction_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "Embedding Extraction p95",
            "refId": "D"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "Database Connections",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "biometric_database_connections_active",
            "legendFormat": "Active Connections",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Connections", "max": 50},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [45], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "name": "High Database Connections"
        }
      },
      {
        "id": 8,
        "title": "Webhook Success Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
        "targets": [
          {
            "expr": "(sum(rate(biometric_webhook_calls_total{status=\"success\"}[5m])) / sum(rate(biometric_webhook_calls_total[5m]))) * 100",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 80, "color": "yellow"},
              {"value": 95, "color": "green"}
            ]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0
          }
        }
      },
      {
        "id": 9,
        "title": "Event Publishing Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
        "targets": [
          {
            "expr": "sum(rate(biometric_events_published_total{success=\"true\"}[5m])) by (event_type)",
            "legendFormat": "{{event_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "eps", "label": "Events/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Embeddings Stored",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "sum(biometric_embeddings_stored_total)",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 11,
        "title": "Active Requests",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 32},
        "targets": [
          {
            "expr": "sum(biometric_active_requests)",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 12,
        "title": "Errors by Type",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "targets": [
          {
            "expr": "sum(biometric_enrollment_errors_total) by (error_code, tenant_id)",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {
                "error_code": "Error Code",
                "tenant_id": "Tenant ID",
                "Value": "Count"
              }
            }
          }
        ]
      }
    ]
  }
}
